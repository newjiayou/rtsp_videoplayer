    <property name="styleSheet">
     <string notr="true">/* 1. 鎬昏建閬?(鑳屽悗鐨勭伆鑹叉潯) */
QSlider::groove:horizontal {
    border: 0px solid #999999;
    height: 4px; /* 杞ㄩ亾鍘氬害锛岃秺灏忚秺绮捐嚧 */
    background: #E0E0E0; /* 娴呯伆鑹茶儗鏅?*/
    border-radius: 2px; /* 鍦嗚 */
}

/* 2. 婊戝潡 (閭ｄ釜鍦嗙悆) */
QSlider::handle:horizontal {
    background: #FFFFFF; /* 绾櫧鐞?*/
    border: 2px solid #409EFF; /* 钃濊壊杈规 */
    width: 14px; /* 鐞冪殑澶у皬 */
    height: 14px;
    border-radius: 9px; /* 鍗婂緞锛屽彉鎴愭鍦?*/
    
    /* 銆愬叧閿€戣鐞冨瀭鐩村眳涓?*/
    /* 璁＄畻鍏紡锛?杞ㄩ亾楂樺害4 - 婊戝潡楂樺害14) / 2 = -5 */
    margin: -5px 0; 
}

/* 3. 宸叉挱鏀剧殑閮ㄥ垎 (钃濊壊鏉? */
QSlider::sub-page:horizontal {
    background: #409EFF; /* 杩欓噷鎹㈡垚浣犲枩娆㈢殑棰滆壊 */
    height: 4px;
    border-radius: 2px;
}

/* 4. 鏈挱鏀剧殑閮ㄥ垎 (閫氬父鍜岃建閬撲竴鏍? */
QSlider::add-page:horizontal {
    background: #E0E0E0;
    height: 4px;
    border-radius: 2px;
}</string>
